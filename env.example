# OpenBriefing MCP Server Configuration
# Copy this file to .env and fill in your values
#
# Contributors / building from source: see AGENTS.md in the repository root.
#
# OpenBriefing covers memory, sessions, briefings, and code. Channel config
# (Discord / GitHub-issue sync / X / Linear tokens) lives in the companion
# unMute project (https://github.com/Paola3stefania/unMute), not here.

# =============================================================================
# Database (REQUIRED — Postgres, no JSON fallback)
# =============================================================================
# OpenBriefing stores sessions, agent memory, and the code index in PostgreSQL.
# If this is unset the server throws on startup. Use a local Postgres for
# development, or a cloud Postgres (Neon / Supabase / Vercel) so the "brain"
# is shared across machines and agents.
#
# LOCAL DEVELOPMENT (macOS):
#   DATABASE_URL=postgresql://$(whoami)@localhost:5432/briefings
# CLOUD:
#   - Neon: postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require
#   - Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=

# Two-mode DB toggle (Optional)
#   OFFLINE_DB=false → Prisma connects to DATABASE_URL (cloud/Neon)
#   OFFLINE_DB=true  → Prisma connects to MEMORY_MIRROR_DATABASE_URL (local)
OFFLINE_DB=false

# Memory Mirror Database URL (Optional)
# When set, every agent memory written to the primary DB is ALSO written to
# this second database in the same call — a live local copy of the "brain".
# Best-effort: a mirror failure never fails the primary write. Auto-disabled
# when the active DB already IS the mirror. The mirror DB must have the same
# schema as primary, INCLUDING pgvector:
#   DATABASE_URL="postgresql://localhost:5432/briefings_local" npm run db:migrate
MEMORY_MIRROR_DATABASE_URL=

# =============================================================================
# Embeddings + LLM Provider
# =============================================================================
# OpenBriefing uses an embedding model for memory search + code index, and an
# LLM for code/feature extraction. Both default to local Ollama (no API key,
# no per-token cost, no rate limits).
#
# Provider: "ollama" (default) | "openai". EMBEDDING_PROVIDER also acts as the
# fallback default for LLM_PROVIDER.
# EMBEDDING_PROVIDER=ollama
# LLM_PROVIDER=ollama

# --- Ollama (default) -------------------------------------------------------
# Install + run once:
#   brew install --cask ollama-app   # (the plain `ollama` formula is missing
#                                     #  the bundled llama-server binary)
#   open -a Ollama                   # starts the local server on :11434
#   ollama pull mxbai-embed-large    # 1024-dim embedding model
#   ollama pull qwen2.5:14b          # chat model for extraction
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
# OLLAMA_CHAT_MODEL=qwen2.5:14b
# EMBEDDING_DIM=1024
#
# All embedding columns are halfvec(1024), so the embedding model MUST emit
# 1024 dims. To move to a higher-dim model (e.g. Qwen3-Embedding) you need a
# new halfvec(N) migration on every embedding column + `npm run reembed:all`.

# --- OpenAI (optional) ------------------------------------------------------
# Only used when EMBEDDING_PROVIDER=openai / LLM_PROVIDER=openai. Note the
# default OpenAI embedding model does NOT emit 1024 dims, so switching requires
# a 1024-dim model (or a new halfvec(N) migration + reembed:all).
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini

# =============================================================================
# Code understanding (Optional)
# =============================================================================
# Lets index_codebase / index_code_for_features / investigate_issue /
# learn_from_pr read your code and your own repo's issues/PRs.

# Local Repository Path (preferred, faster) — read code from the filesystem.
#   - Absolute: /Users/user/Projects/my-project
#   - Relative: ../my-project
LOCAL_REPO_PATH=

# GitHub repo (fallback for index_codebase when no local path; also the repo
# investigate_issue / learn_from_pr read from). Linear format or full URL:
#   - acme-corp/my-project
#   - https://github.com/acme-corp/my-project
GITHUB_REPO_URL=

# GitHub token(s) for higher rate limits when reading issues/PRs (Optional).
# Comma-separated for rotation: token1,token2
GITHUB_TOKEN=

# GitHub App (Optional — highest rate limits; alternative to GITHUB_TOKEN)
# GITHUB_APP_ID=your_app_id
# GITHUB_APP_INSTALLATION_ID=your_installation_id
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/your-app.pem

# =============================================================================
# Session amend window (soft-end) (Optional)
# =============================================================================
# `update_agent_session` normally rejects ended sessions. With soft-end, an
# agent can amend a session for a configurable window after `endedAt` — useful
# when a debrief or follow-up insight arrives after end_agent_session was
# already called. Default 24h; set to `0` to make sessions immutable on end.
# OPENBRIEFING_SESSION_AMEND_WINDOW_MS=86400000        # 24h (default)
