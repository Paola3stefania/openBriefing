{
  "name": "openbriefing",
  "version": "1.0.0",
  "description": "Project context, session memory, and code understanding for AI agents. Briefings, agent sessions, semantic memory, and code indexing — pair with unMute for Discord/GitHub/Linear/X signals.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openbriefing": "./dist/index.js"
  },
  "scripts": {
    "postinstall": "node scripts/ensure-launcher.mjs",
    "setup:launcher": "node scripts/ensure-launcher.mjs",
    "build": "prisma generate && prisma migrate deploy && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "bash scripts/db-cli.sh migrate deploy",
    "db:migrate:dev": "bash scripts/db-cli.sh migrate dev",
    "db:migrate:status": "bash scripts/db-cli.sh migrate status",
    "db:import": "tsx scripts/db-import-json.ts",
    "db:backup": "bash scripts/backup-db.sh",
    "db:setup-local": "bash scripts/setup-local-db.sh",
    "db:seed-local-from-neon": "bash scripts/seed-local-from-neon.sh",
    "db:sync-local-to-neon": "bash scripts/sync-local-to-neon.sh",
    "db:sync": "bash scripts/db-merge.sh",
    "briefing": "tsx scripts/briefing.ts",
    "save-session": "tsx scripts/save-session.ts",
    "setup": "tsx scripts/setup.ts",
    "sync:skill": "node scripts/sync-skill.mjs",
    "backfill:memory-embeddings": "tsx scripts/backfill-memory-embeddings.ts",
    "reembed:all": "tsx scripts/reembed-all.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "agent-memory",
    "session-memory",
    "code-index",
    "cursor",
    "developer-tools",
    "openbriefing"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/auth-app": "^8.0.1",
    "@prisma/client": "^6.19.1",
    "dotenv": "^17.2.3",
    "prisma": "^6.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
