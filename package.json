{
  "name": "openbriefing",
  "version": "1.0.0",
  "description": "Make your agents always up to date out of the box and save up to 80% of token usage. Connects to GitHub, Discord, Slack, and Linear with more integrations coming.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openbriefing": "./dist/index.js"
  },
  "scripts": {
    "postinstall": "node scripts/ensure-launcher.mjs",
    "setup:launcher": "node scripts/ensure-launcher.mjs",
    "build": "prisma generate && prisma migrate deploy && tsc",
    "dev": "tsx src/index.ts",
    "dev:api": "tsx scripts/local-server.ts",
    "start": "node dist/index.js",
    "db:migrate": "bash scripts/db-cli.sh migrate deploy",
    "db:migrate:dev": "bash scripts/db-cli.sh migrate dev",
    "db:migrate:status": "bash scripts/db-cli.sh migrate status",
    "db:import": "tsx scripts/db-import-json.ts",
    "db:backup": "bash scripts/backup-db.sh",
    "db:setup-local": "bash scripts/setup-local-db.sh",
    "db:seed-local-from-neon": "bash scripts/seed-local-from-neon.sh",
    "db:sync-local-to-neon": "bash scripts/sync-local-to-neon.sh",
    "db:sync": "bash scripts/db-merge.sh",
    "test-discord": "tsx scripts/test-discord.ts",
    "read-channel": "tsx scripts/read-channel.ts",
    "list-servers": "tsx scripts/list-servers.ts",
    "list-channels": "tsx scripts/list-channels.ts",
    "read-messages": "tsx scripts/read-messages.ts",
    "check-permissions": "tsx scripts/check-channel-permissions.ts",
    "search-combined": "tsx scripts/search-combined.ts",
    "classify-issues": "tsx scripts/classify-discord-issues.ts",
    "search-specific": "tsx scripts/search-pr-issues.ts",
    "fetch-issues": "tsx scripts/fetch-all-issues.ts",
    "fetch-issues-incremental": "tsx scripts/fetch-all-issues.ts --incremental",
    "fetch-discord": "tsx scripts/fetch-discord-messages.ts",
    "fetch-discord-incremental": "tsx scripts/fetch-discord-messages.ts --incremental",
    "validate-linear": "tsx scripts/validate-linear-setup.ts",
    "briefing": "tsx scripts/briefing.ts",
    "save-session": "tsx scripts/save-session.ts",
    "setup": "tsx scripts/setup.ts",
    "sync:all": "tsx scripts/sync-github-discord.ts",
    "sync:skill": "node scripts/sync-skill.mjs",
    "backfill:memory-embeddings": "tsx scripts/backfill-memory-embeddings.ts",
    "reembed:all": "tsx scripts/reembed-all.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "agent-memory",
    "session-memory",
    "cursor",
    "developer-tools",
    "github",
    "discord",
    "openbriefing"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/auth-app": "^8.0.1",
    "@prisma/client": "^6.19.1",
    "discord.js": "^14.16.3",
    "dotenv": "^17.2.3",
    "prisma": "^6.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
