// Prisma schema for OpenBriefing Database
// Generated from existing migrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Feature {
  id                   String   @id
  name                 String
  description          String?
  category             String?
  priority             String?
  relatedKeywords      String[] @map("related_keywords")
  documentationSection String?  @map("documentation_section")
  documentationUrls    String[] @map("documentation_urls")
  codeContext          String?  @map("code_context") @db.Text
  extractedAt          DateTime @default(now()) @map("extracted_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  embedding    FeatureEmbedding?
  codeMappings FeatureCodeMapping[]
  ownership    FeatureOwnership[]

  @@index([name])
  @@index([category])
  @@index([priority])
  @@index([relatedKeywords], type: Gin)
  @@index([documentationUrls], type: Gin)
  @@index([extractedAt(sort: Desc)])
  @@map("features")
}

model FeatureEmbedding {
  featureId   String                       @id @map("feature_id")
  embedding   Unsupported("halfvec(1024)")
  contentHash String                       @map("content_hash")
  model       String
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([contentHash])
  @@index([model])
  @@map("feature_embeddings")
}

// Lazy code indexing - only index code when searched/needed
model CodeSearch {
  id            String   @id // Hash of search query + repo
  searchQuery   String   @map("search_query") // e.g., "SSO authentication"
  repositoryUrl String   @map("repository_url") // GitHub repo URL
  searchType    String   @map("search_type") // 'semantic', 'keyword', 'exact'
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  codeFiles CodeFile[]

  @@unique([searchQuery, repositoryUrl])
  @@index([repositoryUrl])
  @@index([createdAt(sort: Desc)])
  @@map("code_searches")
}

model CodeFile {
  id            String   @id
  codeSearchId  String   @map("code_search_id")
  filePath      String   @map("file_path")
  fileName      String   @map("file_name")
  fileContent   String   @map("file_content") @db.Text // Full file content
  language      String? // ts, js, py, etc.
  contentHash   String   @map("content_hash") // To detect changes
  lastIndexedAt DateTime @default(now()) @map("last_indexed_at")
  indexedAt     DateTime @default(now()) @map("indexed_at")

  codeSearch   CodeSearch         @relation(fields: [codeSearchId], references: [id], onDelete: Cascade)
  codeSections CodeSection[]
  embeddings   CodeFileEmbedding?

  @@unique([codeSearchId, filePath])
  @@index([codeSearchId])
  @@index([filePath])
  @@index([contentHash])
  @@index([lastIndexedAt])
  @@map("code_files")
}

model CodeSection {
  id             String   @id
  codeFileId     String   @map("code_file_id")
  sectionType    String   @map("section_type") // 'function', 'class', 'interface', 'type', 'export'
  sectionName    String   @map("section_name") // Function/class name
  sectionContent String   @map("section_content") @db.Text // Just this section's code
  startLine      Int?     @map("start_line")
  endLine        Int?     @map("end_line")
  contentHash    String   @map("content_hash")
  createdAt      DateTime @default(now()) @map("created_at")

  codeFile        CodeFile              @relation(fields: [codeFileId], references: [id], onDelete: Cascade)
  embedding       CodeSectionEmbedding?
  featureMappings FeatureCodeMapping[]

  @@index([codeFileId])
  @@index([sectionType])
  @@index([sectionName])
  @@index([contentHash])
  @@map("code_sections")
}

model CodeFileEmbedding {
  codeFileId  String                       @id @map("code_file_id")
  embedding   Unsupported("halfvec(1024)")
  contentHash String                       @map("content_hash")
  model       String
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  codeFile CodeFile @relation(fields: [codeFileId], references: [id], onDelete: Cascade)

  @@index([contentHash])
  @@index([model])
  @@map("code_file_embeddings")
}

model CodeSectionEmbedding {
  codeSectionId String                       @id @map("code_section_id")
  embedding     Unsupported("halfvec(1024)")
  contentHash   String                       @map("content_hash")
  model         String
  createdAt     DateTime                     @default(now()) @map("created_at")
  updatedAt     DateTime                     @updatedAt @map("updated_at")

  codeSection CodeSection @relation(fields: [codeSectionId], references: [id], onDelete: Cascade)

  @@index([contentHash])
  @@index([model])
  @@map("code_section_embeddings")
}

model FeatureCodeMapping {
  id            String   @id
  featureId     String   @map("feature_id")
  codeSectionId String   @map("code_section_id")
  similarity    Decimal  @db.Decimal(5, 4) // 0.0-1.0 cosine similarity
  matchType     String   @map("match_type") // 'semantic', 'keyword', 'exact'
  searchQuery   String?  @map("search_query") // Original search that found this
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  feature     Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)
  codeSection CodeSection @relation(fields: [codeSectionId], references: [id], onDelete: Cascade)

  @@unique([featureId, codeSectionId])
  @@index([featureId])
  @@index([codeSectionId])
  @@index([similarity(sort: Desc)])
  @@index([matchType])
  @@map("feature_code_mappings")
}

// Code ownership analysis based on commit history
model CodeOwnership {
  id               String    @id @default(uuid())
  filePath         String    @map("file_path")
  engineer         String // GitHub username or email prefix (for matching)
  engineerEmail    String?   @map("engineer_email") // Full email for Linear user matching
  engineerName     String?   @map("engineer_name") // Display name from git
  linesAdded       Int       @default(0) @map("lines_added")
  linesDeleted     Int       @default(0) @map("lines_deleted")
  commitsCount     Int       @default(0) @map("commits_count")
  ownershipPercent Decimal   @map("ownership_percent") @db.Decimal(5, 2) // 0.00-100.00
  lastCommitSha    String?   @map("last_commit_sha")
  lastCommitDate   DateTime? @map("last_commit_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([filePath, engineer])
  @@index([filePath])
  @@index([engineer])
  @@index([engineerEmail])
  @@index([ownershipPercent(sort: Desc)])
  @@map("code_ownership")
}

// Feature-level ownership (aggregated from file ownership)
model FeatureOwnership {
  id               String   @id @default(uuid())
  featureId        String   @map("feature_id")
  engineer         String // GitHub username or email prefix (for matching)
  engineerEmail    String?  @map("engineer_email") // Full email for Linear user matching
  engineerName     String?  @map("engineer_name") // Display name from git
  ownershipPercent Decimal  @map("ownership_percent") @db.Decimal(5, 2) // 0.00-100.00
  filesCount       Int      @default(0) @map("files_count")
  totalLines       Int      @default(0) @map("total_lines")
  lastUpdated      DateTime @default(now()) @map("last_updated")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, engineer])
  @@index([featureId])
  @@index([engineer])
  @@index([engineerEmail])
  @@index([ownershipPercent(sort: Desc)])
  @@map("feature_ownership")
}

// ============================================================================
// PR Fix Tools - Learning and Fix Tracking
// ============================================================================

// Track fix attempts for GitHub issues
model FixAttempt {
  id String @id @default(uuid())

  // Issue identification
  issueNumber Int    @map("issue_number")
  issueRepo   String @map("issue_repo") // e.g., "acme-corp/my-project"
  issueTitle  String @map("issue_title")

  // Triage results
  triageResult     String  @map("triage_result") // 'bug' | 'config' | 'feature' | 'question' | 'unclear'
  triageConfidence Decimal @map("triage_confidence") @db.Decimal(3, 2) // 0.00 - 1.00
  triageReasoning  String? @map("triage_reasoning") @db.Text

  // Fix attempt
  fixAttempted Boolean  @default(false) @map("fix_attempted")
  fixSucceeded Boolean? @map("fix_succeeded")

  // PR details (if created)
  prNumber     Int?     @map("pr_number")
  prUrl        String?  @map("pr_url")
  prTitle      String?  @map("pr_title")
  branchName   String?  @map("branch_name")
  filesChanged String[] @default([]) @map("files_changed")

  // If no fix was created
  noFixReason String? @map("no_fix_reason") // 'config_issue' | 'unclear_repro' | 'too_complex' | 'already_fixed'

  // Linear integration
  linearIssueId   String? @map("linear_issue_id")
  linearCommentId String? @map("linear_comment_id") // Comment added about result
  linearUpdated   Boolean @default(false) @map("linear_updated")

  // Timestamps
  attemptedAt DateTime @default(now()) @map("attempted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([issueNumber, issueRepo])
  @@index([triageResult])
  @@index([fixSucceeded])
  @@index([attemptedAt(sort: Desc)])
  @@index([issueRepo])
  @@map("fix_attempts")
}

// ============================================================================
// Agent Briefing System - Session Tracking
// ============================================================================

model AgentSession {
  id               String    @id @default(uuid())
  projectId        String    @default("default") @map("project_id")
  startedAt        DateTime  @default(now()) @map("started_at")
  endedAt          DateTime? @map("ended_at")
  scope            String[]  @default([])
  filesEdited      String[]  @default([]) @map("files_edited")
  decisionsMade    String[]  @default([]) @map("decisions_made")
  openItems        String[]  @default([]) @map("open_items")
  issuesReferenced String[]  @default([]) @map("issues_referenced")
  toolsUsed        String[]  @default([]) @map("tools_used")
  planSteps        Json?     @map("plan_steps") @db.JsonB
  // Typed pointers to artifacts on other surfaces (slack threads, notion pages,
  // github PRs, files, ...). Populated by `link_external_event`. See
  // `ExternalRef` in src/briefing/types.ts for the shape. Default `[]` so old
  // rows read as an empty list without a backfill migration.
  externalRefs     Json      @default("[]") @map("external_refs") @db.JsonB
  summary          String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Memories whose `sessionId` points at this session. Populated when an agent
  // passes `relatedInsights` to end_agent_session.
  memories MemoryEntry[]

  @@index([projectId, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@index([scope], type: Gin)
  @@map("agent_sessions")
}

// Learn from past fixes - stores closed issues with their merged PRs
model PRLearning {
  id String @id @default(uuid())

  // Issue info
  issueNumber Int      @map("issue_number")
  issueRepo   String   @map("issue_repo")
  issueTitle  String   @map("issue_title")
  issueBody   String?  @map("issue_body") @db.Text
  issueLabels String[] @map("issue_labels")
  issueState  String   @map("issue_state") // 'closed'

  // PR info
  prNumber       Int       @map("pr_number")
  prTitle        String    @map("pr_title")
  prBody         String?   @map("pr_body") @db.Text
  prDiff         String    @map("pr_diff") @db.Text // The actual diff
  prFilesChanged String[]  @map("pr_files_changed")
  prLinesAdded   Int       @map("pr_lines_added")
  prLinesRemoved Int       @map("pr_lines_removed")
  prMergedAt     DateTime? @map("pr_merged_at")
  prAuthor       String    @map("pr_author")

  // Classification
  issueType   String   @map("issue_type") // 'bug' | 'feature' | 'docs' | etc.
  subsystem   String? // 'oauth' | 'sso' | etc.
  fixPatterns String[] @map("fix_patterns") // ['null_check', 'error_handling', 'type_fix']

  // Reviewer feedback
  reviewComments Json    @default("[]") @map("review_comments") // Array of review comments
  reviewOutcome  String? @map("review_outcome") // 'approved' | 'changes_requested' | 'merged_without_review'

  // pgvector halfvec(1024), nullable until the post-merge embedding worker
  // computes it. Reads/writes go through src/storage/db/vectorIO.ts; HNSW
  // index ships in 20260603040000_all_embeddings_halfvec.
  embedding   Unsupported("halfvec(1024)")? @map("embedding")
  contentHash String                        @map("content_hash") // For deduplication

  // Timestamps
  learnedAt DateTime @default(now()) @map("learned_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([issueNumber, prNumber, issueRepo])
  @@index([issueRepo])
  @@index([issueType])
  @@index([subsystem])
  @@index([fixPatterns], type: Gin)
  @@index([prMergedAt(sort: Desc)])
  @@map("pr_learnings")
}

// Persistent conversation memory with semantic search
model MemoryEntry {
  id        String   @id @default(uuid())
  projectId String   @default("default") @map("project_id")
  content   String   @db.Text
  summary   String   @db.Text
  tags      String[] @default([])
  source    String   @default("conversation") // 'conversation' | 'manual' | 'session'
  // Optional link back to the session that authored this memory. Set when an
  // agent passes `relatedInsights` to `end_agent_session` (or future automated
  // ingestion). Lets the briefing surface "this insight came from session X"
  // so the next agent can navigate back to the original work unit. Nullable
  // because most memories aren't session-bound (manual save_memory calls,
  // imported context, etc.). `onDelete: SetNull` so deleting a session doesn't
  // orphan or destroy the memory.
  sessionId String?  @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  embedding MemoryEntryEmbedding?
  session   AgentSession?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([tags], type: Gin)
  @@index([sessionId])
  @@map("memory_entries")
}

model MemoryEntryEmbedding {
  memoryId    String                       @id @map("memory_id")
  // pgvector halfvec(1024). Prisma maps halfvec as Unsupported, so this field
  // is NOT selectable/writable via the generated client — all access goes
  // through src/storage/db/vectorIO.ts (writes / single-row reads) and raw
  // SQL `<=>` ANN queries in memory.ts and briefing distill.ts (search). An
  // HNSW cosine index on this column (see migration
  // 20260603040000_all_embeddings_halfvec) powers fast indexed ANN search.
  embedding   Unsupported("halfvec(1024)")
  contentHash String                       @map("content_hash")
  model       String
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  memory MemoryEntry @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("memory_entry_embeddings")
}
